{
    "name": "cmuollo/smart-ad-inserter",
    "description": "WordPress server-side ad inserter for Cumulative Layout Shift (CLS) optimization.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Carmine Muollo"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "SmartAdInserter\\": "includes/",
            "SmartAdInserter\\Admin\\": "admin/",
            "SmartAdInserter\\PublicModule\\": "public/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmartAdInserter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml --testdox"
    }
}
